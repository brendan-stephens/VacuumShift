# Supabase project configuration...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Direct DB URL for worker Vault reads (host → local Supabase Postgres)
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Target DB for register-local (Edge Function in Docker → use host.docker.internal)
LOCAL_TARGET_DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres

# Optional: npm run stack:start creates/syncs this user when BOTH are set (omit to skip)
# DEFAULT_ADMIN_EMAIL=you@example.com
# DEFAULT_ADMIN_PASSWORD=your-password-here

# Worker tuning
WORKER_POLL_INTERVAL_MS=5000
WORKER_JOB_BATCH_SIZE=4

# Full dev stack (after supabase start)
# Start: npm run stack:start
# Stop: npm run stack:stop
